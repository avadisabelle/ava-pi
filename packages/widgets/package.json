{
	"name": "@avadisabelle/ava-widgets",
	"version": "0.64.6",
	"description": "Ava's sacred presence widgets for Pi TUI — echo, ceremony, tools, interceptor, and presence visualization",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"pi": {
		"extensions": [
			"src/ava-ceremony/index.tsx",
			"src/ava-echo/index.tsx",
			"src/ava-interceptor/index.tsx",
			"src/ava-presence/index.tsx",
			"src/ava-tools/index.tsx"
		]
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@avadisabelle/ava-pi-ai": "^0.64.6",
		"@avadisabelle/ava-pi-coding-agent": "^0.64.6",
		"@avadisabelle/ava-pi-tui": "^0.64.6",
		"mia-co": "^0.7.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
